# LLM (OpenAI-compatible API)
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=gpt-4.1-nano-2025-04-14
LLM_PROVIDER=openai

# PostgreSQL (Orange Pi, port 54321 from dev machines)
# Host: pi.home (Tailscale) or 192.168.0.200 (LAN)
DATABASE_URL=postgresql://tgmoderator:CHANGE_ME@pi.home:54321/tgmoderator

# Telegram webhook (HTTPS required; dev: localtunnel → https://your-subdomain.loca.lt)
BASE_URL=
# Per-bot webhook secret is generated in DB when webhook is enabled (Telegram secret_token)

# Better Auth (issue #6)
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3001
# Optional extra origins (comma-separated), e.g. localtunnel HTTPS URL
# BETTER_AUTH_TRUSTED_ORIGINS=https://your-subdomain.loca.lt

# Dev SMTP (Mailpit on pi.home)
SMTP_HOST=pi.home
SMTP_PORT=1025
SMTP_FROM=noreply@tg-moderator.local
