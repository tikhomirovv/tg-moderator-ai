// PostgreSQL (Orange Pi, port 54321 from dev machines)
# Host: pi.home (Tailscale) or 192.168.0.200 (LAN)
DATABASE_URL=postgresql://tgmoderator:CHANGE_ME@pi.home:54321/tgmoderator

# Telegram webhook (HTTPS required; dev: localtunnel → https://your-subdomain.loca.lt)
# Production: public HTTPS URL, same host as users open in browser
BASE_URL=

# Telegram OIDC login (BotFather → Bot Settings → Web Login)
TELEGRAM_LOGIN_BOT_ID=
TELEGRAM_LOGIN_CLIENT_SECRET=

# LLM (OpenAI-compatible API)
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=gpt-4.1-nano-2025-04-14

# Logging (pino): info = production default; debug = verbose troubleshooting
LOG_LEVEL=info

# Container runtime (Docker / production compose)
# PORT=3000
