    "nuxt": "^4.0.3",
    "openai": "^5.12.2",
    "pino": "^9.8.0",
    "pino-pretty": "^13.1.1",
    "postgres": "^3.4.9",
    "vue": "^3.5.18",
    "vue-chartjs": "^5.3.4",
